# ─── REQUIRED ───────────────────────────────────────────
OPENAI_API_KEY=sk-...your-key-here...

# ─── GMAIL ──────────────────────────────────────────────
# Path to your Google OAuth credentials JSON (from Google Cloud Console)
GMAIL_CREDENTIALS_FILE=credentials.json
# Token is auto-created after first login — no need to change
GMAIL_TOKEN_FILE=token.json

# ─── OPTIONAL ───────────────────────────────────────────
# Your name (used in email sign-offs)
USER_NAME=Your Name
# Your email (auto-detected from Gmail if left empty)
USER_EMAIL=

# OpenAI model to use
OPENAI_MODEL=gpt-4o-mini

# Max emails to fetch at once
MAX_EMAILS_FETCH=20

# File to store tasks
TASKS_FILE=tasks.json

# Set to true to allow sending without confirmation (NOT RECOMMENDED)
AUTO_SEND=false
